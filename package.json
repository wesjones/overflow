{
  "name": "overflow-toolbar",
  "version": "0.2.1",
  "type": "module",
  "description": "Responsive toolbar overflow component — items automatically collapse into a dropdown menu as the container shrinks. Supports visible, icon-only (min), and hidden states. Ships with React (Radix UI), MUI, and vanilla JS implementations.",
  "license": "MIT",
  "author": "Wes Jones",
  "repository": {
    "type": "git",
    "url": "https://github.com/wesjones/overflow.git"
  },
  "homepage": "https://wesjones.github.io/overflow/",
  "keywords": [
    "overflow-toolbar",
    "overflow",
    "toolbar",
    "responsive toolbar",
    "overflow menu",
    "adaptive toolbar",
    "collapsible toolbar",
    "responsive buttons",
    "toolbar overflow",
    "action overflow",
    "command bar",
    "button group overflow",
    "responsive action bar",
    "priority+ pattern",
    "priority plus",
    "priority-plus-nav",
    "overflow navigation",
    "responsive navigation",
    "react toolbar",
    "mui toolbar",
    "radix toolbar",
    "resize observer",
    "auto-collapse",
    "icon-only collapse",
    "compact toolbar",
    "toolbar menu",
    "more menu",
    "responsive ui",
    "toolbar component",
    "priority+ navigation",
    "collapsible buttons",
    "toolbar button group",
    "dynamic toolbar",
    "responsive command bar"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/components/Overflow/index.d.ts",
      "import": "./dist/overflow.js",
      "default": "./dist/overflow.js"
    },
    "./rx": {
      "types": "./dist/components/RxOverflow/index.d.ts",
      "import": "./dist/rx.js",
      "default": "./dist/rx.js"
    },
    "./mui": {
      "types": "./dist/components/MuiOverflow/index.d.ts",
      "import": "./dist/mui.js",
      "default": "./dist/mui.js"
    },
    "./vanilla": {
      "types": "./dist/components/NoFrameworkOverflow/index.d.ts",
      "import": "./dist/vanilla.js",
      "default": "./dist/vanilla.js"
    }
  },
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "pnpm run build:lib && pnpm run test:unit",
    "release:patch": "npm version patch && npm publish --access public",
    "release:minor": "npm version minor && npm publish --access public",
    "release:major": "npm version major && npm publish --access public",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "@radix-ui/react-popover": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    },
    "@mui/icons-material": {
      "optional": true
    },
    "@mui/material": {
      "optional": true
    },
    "@radix-ui/react-popover": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.39.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/addon-vitest": "^10.2.14",
    "@storybook/react-vite": "^10.2.14",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "clsx": "^2.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.14",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.576.0",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.2.14",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
